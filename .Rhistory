# 관찰치 행렬과 표준오차 행렬 생성
theta_mat <- cbind(DF4$wle1_A, DF4$wle2_A)        # DDA 정렬된 WLE
error_mat <- cbind(DF4$se_wle1, DF4$se_wle2)      # 대응되는 표준오차
# --- (2) WLE Reliability 계산 ---
rel1 <- 1 - mean(error_mat[,1]^2, na.rm = TRUE) / var(theta_mat[,1], na.rm = TRUE)
rel2 <- 1 - mean(error_mat[,2]^2, na.rm = TRUE) / var(theta_mat[,2], na.rm = TRUE)
# --- (3) 관찰 상관 (Observed Correlation) ---
obs_corr <- cor(theta_mat[,1], theta_mat[,2], use = "pairwise.complete.obs")
# --- (4) 잠재 상관 (Latent Correlation) 보정 ---
latent_corr <- obs_corr / sqrt(rel1 * rel2)
# --- (5) 결과 출력 ---
cat("Observed WLE Correlation =", round(obs_corr, 3), "\n")
cat("Reliability (SR) =", round(rel1, 3), "\n")
cat("Reliability (CR) =", round(rel2, 3), "\n")
cat("Latent Correlation =", round(latent_corr, 3), "\n")
DF1 <- DF1 %>%
mutate(
item_clean = str_remove(item, "(_MCMC.*|_OEOEOE|_FB|_NU)$"),
item_clean = str_replace(item_clean, "(\\.\\d+)[a-zA-Z]+", "\\1")
)
PAIRDATA_OVERALL <- DF1 %>%
mutate(type = ifelse(dim == 1, "SR", "CR")) %>%
select(item_clean, type, ESTIMATE_A) %>%
pivot_wider(
names_from = type,
values_from = ESTIMATE_A
) %>%
drop_na(SR, CR)
# --- (3) 상관계수 계산 ---
correlation_overall <- cor(PAIRDATA_OVERALL$SR, PAIRDATA_OVERALL$CR, use = "complete.obs")
# --- (4) 공통 축 범위 설정 ---
x_min <- min(c(PAIRDATA_OVERALL$SR, PAIRDATA_OVERALL$CR), na.rm = TRUE)
x_max <- max(c(PAIRDATA_OVERALL$SR, PAIRDATA_OVERALL$CR), na.rm = TRUE)
# --- (5) 시각화 (DDA 정렬 후 Overall Difficulty) ---
p_overall <- ggplot(PAIRDATA_OVERALL, aes(x = SR, y = CR, label = item_clean)) +
geom_point(color = "blue", size = 3, alpha = 0.8) +
geom_smooth(method = "lm", color = "red", se = TRUE, linewidth = 1.2, fullrange = TRUE) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "black", linewidth = 1) +
geom_text_repel(size = 3.5, box.padding = 0.5, point.padding = 0.3, max.overlaps = 15) +
ggtitle(paste0("CR and Human-Generated SR (r = ", round(correlation_overall, 2), ")")) +
xlab("Human-SR Overall Difficulty") +
ylab("CR Overall Difficulty") +
scale_x_continuous(limits = c(0, 3), expand = expansion(mult = 0.05)) +  # ✅ 시각적 범위만 조정
scale_y_continuous(limits = c(0, 3), expand = expansion(mult = 0.05)) +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
axis.text = element_text(size = 10),
axis.title = element_text(size = 12, face = "bold")
) +
coord_fixed(ratio = 1, xlim = c(0, 2.0), ylim = c(0, 2))
p_overall
# --- (1) DF3 아이템 이름 정리: SR/CR 매칭용 공통 item_clean 생성 ---
DF3 <- DF3 %>%
mutate(
item_clean = str_remove(item, "(_MCMC.*|_OEOEOE|_FB|_NU)$"),
item_clean = str_replace(item_clean, "(\\.\\d+)[a-zA-Z]+", "\\1")
)
# --- (2) Threshold SR–CR wide-format으로 정렬 ---
PAIRDATA_WIDE2 <- DF3 %>%
mutate(type = ifelse(dim == 1, "SR", "CR")) %>%
select(item_clean, category = level, type, threshold_A) %>%
pivot_wider(names_from = type, values_from = threshold_A) %>%
drop_na(SR, CR)
# --- (3) 상관계수 계산 ---
correlation_coefficient2 <- cor(PAIRDATA_WIDE2$SR, PAIRDATA_WIDE2$CR, use = "complete.obs")
# --- (4) 플롯 ---
p_threshold <- ggplot(PAIRDATA_WIDE2, aes(x = SR, y = CR, color = as.factor(category))) +
geom_point(size = 3, alpha = 0.8) +
geom_smooth(method = "lm", color = "red", se = TRUE, linewidth = 1.2) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "black", linewidth = 1) +
geom_text_repel(
aes(label = item_clean),
size = 3.5, box.padding = 0.5, point.padding = 0.3, max.overlaps = 15
) +
scale_color_manual(values = c("blue", "darkgreen", "purple", "orange")) +
ggtitle(paste0("CR and Human-Generated SR (r = ", round(correlation_coefficient2, 2),")")) +
xlab("Human-SR Threshold") +
ylab("CR Threshold") +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
axis.text = element_text(size = 10),
axis.title = element_text(size = 12, face = "bold"),
legend.title = element_text(size = 10, face = "bold"),
legend.text = element_text(size = 10)
) +
coord_fixed(ratio = 1, xlim = c(-3, 5), ylim = c(-3, 5)) +  # ✅ 여기서 조정
labs(color = "Category")
