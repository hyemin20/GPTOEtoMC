error_mat <- cbind(DF4$se_wle1, DF4$se_wle2)  # Corresponding SEs
rel1 <- 1 - mean(error_mat[,1]^2, na.rm = TRUE) / var(theta_mat[,1], na.rm = TRUE)
rel2 <- 1 - mean(error_mat[,2]^2, na.rm = TRUE) / var(theta_mat[,2], na.rm = TRUE)
cor(DF4$wle1_A, DF4$wle2_A, use = "pairwise.complete.obs")
obs_corr <- cor(DF4$wle1_A, DF4$wle2_A, use = "pairwise.complete.obs")
latent_corr <- obs_corr / sqrt(rel1 * rel2)
### Boxplot
thetaO <- data.frame(Dim1 = DF4$wle1, Dim2 = DF4$wle2)
thetaA <- data.frame(Dim1 = DF4$wle1_A, Dim2 = DF4$wle2_A)
personOL <- pivot_longer(thetaO, cols = everything(), names_to = "Dimension", values_to = "WLE") %>%
mutate(Dimension = recode(Dimension, "Dim1" = "SR", "Dim2" = "CR"))
personAL <- pivot_longer(thetaA, cols = everything(), names_to = "Dimension", values_to = "WLE") %>%
mutate(Dimension = recode(Dimension, "Dim1" = "SR", "Dim2" = "CR"))
# 순서 고정
personOL$Dimension <- factor(personOL$Dimension, levels = c("SR", "CR"))
personAL$Dimension <- factor(personAL$Dimension, levels = c("SR", "CR"))
p1 <- ggplot(personOL, aes(x = Dimension, y = WLE)) +
geom_boxplot(fill = "lightblue", color = "black") +
labs(title = "Original", x = "Dimension", y = "WLE theta") +
ylim(-3, 5.5) +
theme_minimal() +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
p2 <- ggplot(personAL, aes(x = Dimension, y = WLE)) +
geom_boxplot(fill = "lightyellow", color = "black") +
labs(title = "Aligned", x = "Dimension", y = "WLE theta") +
ylim(-3, 5.5) +
theme_minimal() +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
p1 + p2
### comparison
comparison_df <- data.frame(
Dimension = c("Dim 1", "Dim 2"),
Original_Mean = colMeans(thetaO, na.rm = TRUE),
Original_SD   = apply(thetaO, 2, sd, na.rm = TRUE),
Aligned_Mean  = colMeans(thetaA, na.rm = TRUE),
Aligned_SD    = apply(thetaA, 2, sd, na.rm = TRUE)
)
print(comparison_df)
### Aligned SR vs CR
correlation_overall = cor(thetaA$Dim1, thetaA$Dim2, use = "pairwise.complete.obs")
ggplot(thetaA, aes(x = Dim1, y = Dim2)) +
geom_point(color = "blue") +
labs(
title = paste0("CR and SR Student Locations"),
x = "EAP (Human-SR)",
y = "EAP (CR)") +
xlim(-3.1, 3.1) + ylim(-3.1, 3.1) +
theme_minimal() +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
