mutate(
item_clean = str_remove(item, "(_MCMC.*|_OEOEOE|_FB|_NU)$"),
item_clean = str_replace(item_clean, "(\\.\\d+)[a-zA-Z]+", "\\1")
)
# --- (2) Threshold SR–CR wide-format으로 정렬 ---
PAIRDATA_WIDE2 <- DF3 %>%
mutate(
type = if_else(dim == 1, "SR", "CR"),
level_num = as.integer(as.character(level)),   # level이 factor/chr 대비
category = sprintf("%d/%d", level_num, level_num + 1)
) %>%
select(item_clean, category, type, threshold_A) %>%
group_by(item_clean, category, type) %>%
summarise(threshold_A = mean(threshold_A, na.rm = TRUE), .groups = "drop") %>%
pivot_wider(names_from = type, values_from = threshold_A) %>%
drop_na(SR, CR)
# --- (3) 상관계수 계산 ---
correlation_coefficient2 <- cor(PAIRDATA_WIDE2$SR, PAIRDATA_WIDE2$CR, use = "complete.obs")
# --- (4) 플롯 ---
p_threshold <- ggplot(PAIRDATA_WIDE2, aes(x = SR, y = CR, color = as.factor(category))) +
geom_point(size = 3, alpha = 0.8) +
geom_smooth(method = "lm", color = "red", se = TRUE, linewidth = 1.2) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "black", linewidth = 1) +
geom_text_repel(
aes(label = item_clean),
size = 3.5, box.padding = 0.5, point.padding = 0.3, max.overlaps = 15
) +
scale_color_manual(values = c("blue", "darkgreen", "purple", "orange")) +
ggtitle(paste0("CR and SR Threshold (r = ", round(correlation_coefficient2, 2),")")) +
xlab("SR Threshold") +
ylab("CR Threshold") +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
axis.text = element_text(size = 10),
axis.title = element_text(size = 12, face = "bold"),
legend.title = element_text(size = 10, face = "bold"),
legend.text = element_text(size = 10)
) +
coord_fixed(ratio = 1, xlim = c(-3, 5), ylim = c(-3, 5)) +  # ✅ 여기서 조정
labs(color = "Category")
p_threshold
ggsave(
filename = "scatter_aligned_sr_cr.png",
plot = p_threshold,
device = ragg::agg_png,
width = 12, height = 12, units = "cm",
res = 450, background = "white"
)
library(dplyr); library(readxl); library(stringr); library(writexl); library(tidyr)
df <- read_excel("C:/Users/Hyemi/Downloads/A.xlsx")
combind <- df %>%
select(-`Respondent Id`, -`Assignment Id`, -Class, -matches("^(D/.|STEM\\.)")) %>%
# 행: 모든 값이 NA 또는 0이면 제거
filter(!if_all(everything(), ~ is.na(.) | . == 0)) %>%
# 열: 모든 값이 NA 또는 0이면 제거
select(where(~ !all(is.na(.) | . == 0))) %>%
mutate(StuID = row_number())
combind
response_count_by_item <- combind %>%
summarise(across(
matches("(?i)pop\\.07|wildlife\\."),
~ sum(!is.na(.))
)) %>%
pivot_longer(
everything(),
names_to = "item",
values_to = "n_response"
)
response_count_by_item
