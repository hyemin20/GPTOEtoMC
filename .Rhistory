install.packages("ragg")
library(ragg)
# (p1 + p2) 저장
ggsave(
filename = "boxplots_original_aligned.png",
plot = p1 + p2,
device = ragg::agg_png,
width = 18, height = 9, units = "cm",
res = 400, background = "white"
)
# scatter 저장
p_scatter <- ggplot(thetaA, aes(x = Dim1, y = Dim2)) +
geom_point(color = "blue", size = 1.2, alpha = 0.7) +
labs(
title = paste0("CR and SR Student Locations (r = ", round(correlation_overall, 3), ")"),
x = "EAP (SR)", y = "EAP (CR)"
) +
coord_cartesian(xlim = c(-3.1, 3.1), ylim = c(-3.1, 3.1)) +
theme_minimal(base_size = 12) +
theme(plot.title = element_text(hjust = 0.5, face = "bold"))
ggsave(
filename = "scatter_aligned_sr_cr.png",
plot = p_scatter,
device = ragg::agg_png,
width = 12, height = 12, units = "cm",
res = 450, background = "white"
)
